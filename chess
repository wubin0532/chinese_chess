    evaluate() {
        let phaseMat = 0;
        let rKing = null, bKing = null;
        let rA = 0, rE = 0, bA = 0, bE = 0;
        
        for(let r=0; r<10; r++) for(let c=0; c<9; c++) {
            const k = this.map[r][c];
            if(k) { 
                const t=k.toLowerCase(); 
                if(t==='r'||t==='c'||t==='n') phaseMat++; 
                if (k === 'K') rKing = {r, c}; else if (k === 'k') bKing = {r, c};
                else if (k === 'A' || k === 'S') rA++; else if (k === 'B' || k === 'X') rE++;
                else if (k === 'a' || k === 's') bA++; else if (k === 'b' || k === 'x') bE++;
            }
        }
        let phase = phaseMat / 12.0; if(phase>1) phase=1;
        const val_c = Math.floor(350 + 100 * phase);
        const val_n = Math.floor(450 - 50 * phase);

        let s = 0;
        for(let r=0; r<10; r++) for(let c=0; c<9; c++) {
            const k = this.map[r][c];
            if(!k) continue;
            const t = k.toLowerCase(), isRed = k<'a';
            let v = 0;
            if(t==='c') v = val_c; else if(t==='n') v = val_n; else v = EvalC.vals[t] || 0;
            if(EvalC.pst[t] && EvalC.pst[t][isRed ? 9-r : r]) {
                v += EvalC.pst[t][isRed ? 9-r : r][c] || 0;
            }
            
            let mobility = 0, threat = 0;
            if (t === 'r') {
                const rDir = isRed ? 1 : -1; let isOpen = true;
                for(let nr = r + rDir; nr >= 0 && nr < 10; nr += rDir) {
                    const p = this.map[nr] && this.map[nr][c];
                    if(p) { if(p.toLowerCase() === 'p' && (p < 'a') === isRed) isOpen = false; break; }
                }
                if(isOpen) mobility += 25;
            } else if (t === 'p') {
                const crossed = (isRed && r <= 4) || (!isRed && r >= 5);
                if(crossed) { mobility += 30; if(c >= 3 && c <= 5) mobility += 15; }
                const pDir = isRed ? -1 : 1; let isPassed = true;
                for(let nr = r + pDir; nr >= 0 && nr < 10; nr += pDir) {
                    const p = this.map[nr] && this.map[nr][c];
                    if(p) { if(p.toLowerCase() === 'p') isPassed = false; break; }
                }
                if(isPassed && crossed) mobility += 20;
            }
            s += isRed ? (v + mobility) : -(v + mobility); 
        }
        return s;
    },

    getNotation(map, m) {
        const p = map[m.fr][m.fc];
        if (!p) return "";
        const isRed = p < 'a', t = p.toLowerCase();
        const nRed = {'p':'兵','c':'炮','r':'车','n':'马','b':'相','a':'仕','k':'帅'};
        const nBlk = {'p':'卒','c':'砲','r':'車','n':'馬','b':'象','a':'士','k':'將'};
        const cRed = ['九','八','七','六','五','四','三','二','一'];
        const cBlk = ['1','2','3','4','5','6','7','8','9'];
        const numR = ['一','二','三','四','五','六','七','八','九'];
        const numB = ['1','2','3','4','5','6','7','8','9'];

        const name = isRed ? nRed[t] : nBlk[t];
        let startCol = isRed ? cRed[m.fc] : cBlk[m.fc];

        let sameCount = 0, p1R = -1, p2R = -1;
        for(let r=0; r<10; r++) {
            if(map[r][m.fc] === p) {
                sameCount++;
                if(p1R === -1) p1R = r; else p2R = r;
            }
        }

        let prefix = name + startCol;
        if (sameCount === 2 && (t==='c'||t==='r'||t==='n'||t==='p')) {
            if(isRed) prefix = (m.fr === p1R ? "前" : "后") + name; 
            else prefix = (m.fr === p2R ? "前" : "后") + name; 
        }

        let dir = "";
        if(m.tr === m.fr) dir = "平";
        else if(isRed) dir = m.tr < m.fr ? "进" : "退";
        else dir = m.tr > m.fr ? "进" : "退";

        let end = "";
        if (dir === "平" || t === 'n' || t === 'b' || t === 'a' || t === 'x' || t === 's' || t === 'm') {
            end = isRed ? cRed[m.tc] : cBlk[m.tc];
        } else {
            const steps = Math.abs(m.tr - m.fr);
            end = isRed ? numR[steps-1] : numB[steps-1];
        }

        return prefix + dir + end;
    },

    checkOpeningBook(map, historyMaps, turnColor) {
        const isRedTurn = (turnColor === 'r');
        const strKey = map.flat().join('');
        const initialKey = "rnbakabnr0000000000c00000c0p0p0p0p0p000000000000000000P0P0P0P0P0C00000C0000000000RNBAKABNR";
        
        if (strKey === initialKey && historyMaps.length === 0 && isRedTurn) {
            const book = [
                {fc:7, fr:7, tc:4, tr:7}, {fc:1, fr:7, tc:4, tr:7}, 
                {fc:6, fr:6, tc:6, tr:5}, {fc:2, fr:6, tc:2, tr:5}, 
                {fc:6, fr:9, tc:4, tr:7}, {fc:2, fr:9, tc:4, tr:7}, 
                {fc:7, fr:9, tc:6, tr:7}, {fc:1, fr:9, tc:2, tr:7}
            ];
            return book[Math.floor(Math.random() * book.length)];
        }
        if (historyMaps.length === 1 && !isRedTurn) {
            let move = null;
            if (map[7][4] === 'C') { 
                const res = [{fc:7, fr:0, tc:6, tr:2}, {fc:1, fr:0, tc:2, tr:2}, {fc:7, fr:2, tc:4, tr:2}, {fc:1, fr:2, tc:4, tr:2}];
                move = res[Math.floor(Math.random() * res.length)];
            } else if (map[5][6] === 'P') { 
                const res = [{fc:7, fr:2, tc:6, tr:2}, {fc:2, fr:3, tc:2, tr:4}, {fc:2, fr:0, tc:4, tr:2}];
                move = res[Math.floor(Math.random() * res.length)];
            } else if (map[5][2] === 'P') { 
                const res = [{fc:1, fr:2, tc:2, tr:2}, {fc:6, fr:3, tc:6, tr:4}, {fc:6, fr:0, tc:4, tr:2}];
                move = res[Math.floor(Math.random() * res.length)];
            } else if (map[7][4] === 'B') { 
                const res = [{fc:7, fr:2, tc:4, tr:2}, {fc:1, fr:2, tc:4, tr:2}, {fc:7, fr:0, tc:6, tr:2}];
                move = res[Math.floor(Math.random() * res.length)];
            } else if (map[7][6] === 'N' || map[7][2] === 'N') { 
                const res = [{fc:6, fr:3, tc:6, tr:4}, {fc:2, fr:3, tc:2, tr:4}, {fc:7, fr:2, tc:4, tr:2}];
                move = res[Math.floor(Math.random() * res.length)];
            } else {
                const res = [{fc:7, fr:0, tc:6, tr:2}, {fc:1, fr:0, tc:2, tr:2}, {fc:2, fr:0, tc:4, tr:2}];
                move = res[Math.floor(Math.random() * res.length)];
            }
            return move;
        }
        return null;
    },

    async runWorkers(map, depth, historyMaps, turnColor) {
        this.isInterrupted = false; 
        const bookMove = this.checkOpeningBook(map, historyMaps, turnColor);
        if (bookMove) {
            UI.log("💡 触发国家大师级名谱，0毫秒响应", "sys");
            return bookMove;
        }

        const currentEpoch = this.workerEpoch;
        this.pendingResolves = []; 
        
        if (this.sharedTTBuffer) {
            new Int8Array(this.sharedTTBuffer, 10 * 8388608, 8388608).fill(-1);
        }
        
        const promises = this.workers.map((worker, i) => {
            return new Promise(resolve => {
                this.pendingResolves.push(resolve);
                worker.onmessage = e => resolve(e.data);
                worker.postMessage({ type: 'go', map, depth, historyMaps, turn: turnColor, workerId: i, totalWorkers: this.numWorkers, sharedTT: this.sharedTTBuffer });
            });
        });

        const results = await Promise.all(promises);
        this.pendingResolves = []; 
        
        if (this.isInterrupted || currentEpoch !== this.workerEpoch) return null;

        let bestMove = null;
        let bestVal = (turnColor === 'r') ? -Infinity : Infinity;

        for (let res of results) {
            if (res && res.move) {
                if (turnColor === 'r') { 
                    if (res.val > bestVal) { bestVal = res.val; bestMove = res.move; }
                } else { 
                    if (res.val < bestVal) { bestVal = res.val; bestMove = res.move; }
                }
            }
        }
        return bestMove;
    },

    async hint() {
        if(this.gameOver || this.editMode || this.isThinking || this.isAnimating) return; 
        this.isThinking = true;
        
        UI.status("LazySMP 并发神经预测中...", true);
        this.hintMove = null;
        const d = parseInt(document.getElementById('depth').value);
        
        await new Promise(r => setTimeout(r, 50));
        const bestMove = await this.runWorkers(this.map, d, this.history, this.turn);
        
        this.isThinking = false;
        if(this.isInterrupted || this.gameOver || this.editMode) return; 
        
        UI.status(this.turn==='r' ? "红方走棋" : "黑方走棋", false);
        if(bestMove) {
            this.hintMove = bestMove;
            this.draw();
            const notStr = this.getNotation(this.map, bestMove);
            UI.log(`💡 预测最佳走法: [${notStr}]`, 'sys');
        } else { 
            UI.log("💡 局面已死锁，无有效走法", 'warn'); 
        }
    },

