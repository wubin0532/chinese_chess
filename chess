        if (this.hintMove && !Particles.animating) {
            const m = View.margin, g = View.grid, hm = this.hintMove;
            const fx = c => View.flipped ? 8 - c : c;
            const fy = r => View.flipped ? 9 - r : r;
            View.ctx.beginPath();
            View.ctx.moveTo(m + fx(hm.fc) * g, m + fy(hm.fr) * g); 
            View.ctx.lineTo(m + fx(hm.tc) * g, m + fy(hm.tr) * g);
            View.ctx.strokeStyle = '#ff9f0a'; 
            View.ctx.lineWidth = 4; 
            View.ctx.setLineDash([8, 8]); 
            View.ctx.stroke();
            View.ctx.setLineDash([]); 
            View.mark(fx(hm.fc), fy(hm.fr), '#ff9f0a'); 
            View.mark(fx(hm.tc), fy(hm.tr), '#ff9f0a');
        }
    },

